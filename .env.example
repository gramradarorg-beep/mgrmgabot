# Скопируй в .env и заполни. Файл .env НЕ коммить.

# Токен бота от @BotFather
TELEGRAM_BOT_TOKEN=123456:ABC-DEF...

# Канал, куда постим. Бот должен быть админом канала.
# Публичный: @mgrmga_holders   |   приватный: числовой id вида -1001234567890
CHANNEL_ID=@mgrmga_holders

# Ключ TonAPI (tonconsole.com -> TonAPI). Без него будет жёсткий лимит.
TONAPI_KEY=

# Адрес пула MGRMGA/TON на STON.fi (появится ПОСЛЕ создания пула).
# Именно его транзакции мы слушаем.
POOL_ADDRESS=

# Мастер-контракт токена (jetton). Нужен для строки с ценой и % за 24ч.
JETTON_MASTER=EQDnthM6DjZLIlQ_lQlCwtj-Ez2UrYzpWUV493bcccz-Rj0c

# Символ токена (как в метадате). По умолчанию MGRMGA.
TOKEN_SYMBOL=MGRMGA

# Куда ведёт кнопка «Купить». ОСТАВЬ ПУСТЫМ → бот сам построит прямую ссылку на свап
# STON.fi по адресу токена (ft=GRAM). Заполни, только если нужен другой адрес назначения.
BUY_LINK=

# Не постить сделки меньше этого объёма в TON (0 = постить все). Напр. 1 — отсекать пыль.
MIN_TON=0

# Как часто опрашивать TonAPI, мс (минимум 5000).
POLL_INTERVAL_MS=15000

# 1 = при первом запуске запостить и уже существующие сделки. 0 = стартуем «с чистого листа».
SEED_POST=0
